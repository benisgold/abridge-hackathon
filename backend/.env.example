# Copy to .env and fill in.

# Master switch for the Claude (Anthropic API key) extraction agent.
# false (default) = never call the API; always use the deterministic CSV replay.
# true = allow live extraction (also requires EXTRACTION_MODE=live + a key below).
ANTHROPIC_ENABLED=false

# Only used when ANTHROPIC_ENABLED=true. "live" calls Claude; "csv" replays.
EXTRACTION_MODE=csv

# Required only when the live agent is enabled.
ANTHROPIC_API_KEY=
